# Server
PORT=8080
NODE_ENV=production

# Supabase (same project as backend, but agent-brain only touches leads/scrape_jobs read+update)
ANON_PUBLIC=YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash
RESEND_API_KEY=YOUR_RESEND_API_KEY
# ^ set to whatever current Gemini model you have access to; flash-tier is recommended
#   for this loop since it runs many times per lead and latency/cost compound fast.

# Backend services (the automated instance, NOT the manual/live-website one)
AGENTIC_BACKEND_URL=https://your-scraper-automated.up.railway.app

# TinyFish (free Search + Fetch; Agent API is paid, used sparingly)
TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://api.tinyfish.ai

# Loop tuning
MAX_ATTEMPTS_PER_LEAD=5
MAX_CONCURRENT_LEADS=8
MAX_PAID_TOOL_CALLS_PER_LEAD=2
TOOL_CALL_TIMEOUT_MS=20000
GEMINI_CALL_TIMEOUT_MS=25000
